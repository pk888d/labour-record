# Dependencies
labour-record-app/node_modules/

# Next.js build output
labour-record-app/.next/
labour-record-app/out/

# Database (contains real data — back up separately)
labour-record-app/prisma/dev.db
labour-record-app/prisma/dev.db-shm
labour-record-app/prisma/dev.db-wal
labour-record-app/prisma/*.db.backup.*

# Prisma generated client (regenerated by install.sh)
labour-record-app/src/generated/

# Environment variables (may contain secrets)
labour-record-app/.env
labour-record-app/.env.local
labour-record-app/.env*.local

# Generated exports
labour-record-app/exports/

# OS
.DS_Store
**/.DS_Store

# Test reports
labour-record-app/playwright-report/
labour-record-app/test-results/

# Logs
*.log
npm-debug.log*

# Editor
.vscode/
.idea/
*.swp

# Superpowers tooling cache (local)
.superpowers/

# Microsoft Office lock/temp files
~$*

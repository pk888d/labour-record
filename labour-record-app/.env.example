# Copy to .env and fill in. .env is gitignored.

# Prisma database connection string.
DATABASE_URL=

# --- Print registers ---
# How many employees are listed per printed sheet of a row-table register
# (Form V/XII/XI/IV/I/II, Shop W/V/X). When the roster exceeds this, the register
# splits across multiple sheets and the statutory header repeats on each.
# Optional — defaults to 20 if unset. Effectively capped at the single-sheet
# ceiling (~23 landscape / ~36 portrait) so a sheet never overflows its header.
PRINT_MAX_ROWS_PER_SHEET=20

# Below this employee count, table rows stretch taller to fill the whole page
# instead of clustering at the top. Optional — defaults to 5 if unset.
PRINT_MIN_FILL_ROWS=5
